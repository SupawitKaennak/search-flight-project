# Frontend Environment Variables Example
# Copy this file to .env.frontend and update the values as needed
#
# Usage:
#   Windows PowerShell: Copy-Item .env.frontend.example .env.frontend
#   Linux/Mac: cp .env.frontend.example .env.frontend
#
# IMPORTANT: Next.js reads NEXT_PUBLIC_* variables at BUILD TIME, not runtime!
# You must rebuild the Docker image after changing these values:
#   docker-compose -f frontend/docker-compose.frontend.yml build --build-arg NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=your_key
#   docker-compose -f frontend/docker-compose.frontend.yml up -d

# ============================================
# Node Environment
# ============================================

NODE_ENV=production

# ============================================
# API Configuration
# ============================================

# Backend API URL
# Default: http://localhost:3001/api
# Change this to your actual backend API URL when ready
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ============================================
# Data Source Configuration
# ============================================

# Use mock data instead of real API
# Options:
#   - true: Use mock data (for development/testing)
#   - false: Use real API from NEXT_PUBLIC_API_URL (default)
# 
# Note: Default is 'false' to use real backend API
# Set to 'true' only if you want to use mock data for testing
NEXT_PUBLIC_USE_MOCK_DATA=false

# ============================================
# Weather API Configuration
# ============================================

# OpenWeatherMap API Key
# Get your free API key from: https://openweathermap.org/api
# Free tier allows 60 calls/minute and 1,000,000 calls/month
# 
# IMPORTANT: This must be set as build arg when building Docker image:
#   docker-compose -f frontend/docker-compose.frontend.yml build --build-arg NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=your_api_key_here
NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=your_api_key_here
