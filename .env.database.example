# Database Environment Variables Example
# Copy this file to .env.database and update the values as needed
#
# Usage:
#   Windows PowerShell: Copy-Item .env.database.example .env.database
#   Linux/Mac: cp .env.database.example .env.database

# PostgreSQL User
POSTGRES_USER=postgres

# PostgreSQL Password
POSTGRES_PASSWORD=postgres

# Database Name
POSTGRES_DB=flight_search

# PostgreSQL Initialization Arguments
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C
