# Files to ignore when deploying to Render
# Similar to .gitignore but specific to Render deployment

# Environment files (use Render environment variables instead)
.env
.env.*
!.env*.example

# Development files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker override files
docker-compose.override.yml

# Documentation (optional - can be included)
# docs/

# Scripts that are not needed in production
# backend/scripts/check-*.js
# backend/scripts/debug-*.js
