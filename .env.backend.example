# Backend Environment Variables Example
# Copy this file to .env.backend and update the values as needed
#
# Usage:
#   Windows PowerShell: Copy-Item .env.backend.example .env.backend
#   Linux/Mac: cp .env.backend.example .env.backend

# ============================================
# Server Configuration
# ============================================

# Server Port
PORT=3001

# Node Environment (development, production)
NODE_ENV=production

# ============================================
# Database Configuration
# ============================================

# Database Host
# หมายเหตุ: ถ้าใช้ docker-compose.database.yml ให้ใช้ "flight_search_db"
# ถ้าใช้ docker-compose.yml (รวมทุก service) ให้ใช้ "postgres"
DB_HOST=flight_search_db

# Database Port
DB_PORT=5432

# Database Name
DB_NAME=flight_search

# Database User
DB_USER=postgres

# Database Password
DB_PASSWORD=postgres

# ============================================
# TimescaleDB Configuration
# ============================================

# Enable TimescaleDB Extension
ENABLE_TIMESCALEDB=true

# ============================================
# CORS Configuration
# ============================================

# CORS Origin (Frontend URL)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Rate Limiting Configuration
# ============================================

# Rate Limit Window (milliseconds)
RATE_LIMIT_WINDOW_MS=60000

# Max Requests Per Window
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================
# Scheduled Jobs Configuration
# ============================================

# Enable/Disable Scheduled Background Jobs
ENABLE_SCHEDULED_JOBS=false
